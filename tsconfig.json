{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2023",

    "module": "commonjs",
    "moduleResolution": "node",

    "esModuleInterop": true,
    "strict": true,

    "skipLibCheck": true,

    "sourceMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "ignoreDeprecations": "6.0"
  },

  "include": ["src"],

  "exclude": ["dist", "node_modules"]
}